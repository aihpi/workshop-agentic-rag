# Loaded into the Langflow container at startup. With
# LANGFLOW_STORE_ENVIRONMENT_VARIABLES=true (set in docker-compose.yml), each
# entry below is auto-imported as a Langflow Global Variable.

# ─────────────────────────────────────────────────────────────────────────────
# HPI AI Science Center — Model Hub
# Obtain your key at https://api.aisc.hpi.de
# Required: every flow's LiteLLM + Embeddings nodes reference these globals.
# ─────────────────────────────────────────────────────────────────────────────
AISC_API_KEY=your_hpi_aisc_api_key_here
AISC_BASE_URL=https://api.aisc.hpi.de

# ─────────────────────────────────────────────────────────────────────────────
# Qdrant — Vector Database
# QDRANT_API_KEY: leave empty for local Qdrant with no auth.
# QDRANT_URL: only used as a Langflow Global Variable; the Qdrant nodes in the
# flows hard-code http://qdrant:6333 (compose service name).
# ─────────────────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# NOTE — Tavily (Flow 3, 5) and Prior Labs (Flow 6) keys are NOT loaded from
# this file. Paste them directly into:
#   - Settings → MCP Servers → tavily_search → URL ?tavilyApiKey=<key>
#   - Settings → MCP Servers → tabpfn → headers Authorization: Bearer <key>
# Get keys at https://tavily.com and https://ux.priorlabs.ai .
# ─────────────────────────────────────────────────────────────────────────────
