# ─────────────────────────────────────────────────────────────────────────────
# HPI AI Science Center — Model Hub
# Obtain your key at https://api.aisc.hpi.de
# ─────────────────────────────────────────────────────────────────────────────
AISC_API_KEY=your_hpi_aisc_api_key_here
AISC_BASE_URL=https://api.aisc.hpi.de

# ─────────────────────────────────────────────────────────────────────────────
# Qdrant — Vector Database
# Leave QDRANT_API_KEY empty for a local Qdrant instance with no auth.
# ─────────────────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Web Search MCP (used in Flow 5 — optional)
# Get a free key at https://tavily.com
# ─────────────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# TabPFN MCP (used in Flow 6 — optional)
# Get a free key (100 M credits/day) at https://ux.priorlabs.ai → Access Tokens.
# In Langflow, paste it as the `Authorization: Bearer <key>` header when you
# register the `tabpfn` MCP server under Settings → MCP Servers.
# ─────────────────────────────────────────────────────────────────────────────
PRIORLABS_API_KEY=your_priorlabs_api_key_here
