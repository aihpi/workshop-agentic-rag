# LiteLLM (embedding endpoint)
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=your-key
EMBED_MODEL=text-embedding-3-large

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=grundschutz

# Ingestion limits
MAX_FILE_SIZE_MB=50
CHUNK_MAX_CHARS=3000
CHUNK_OVERLAP=300
EMBED_BATCH_SIZE=64
EMBED_MAX_BATCH_CHARS=20000

# Chainlit auth (optional)
CHAINLIT_AUTH_SECRET=change-me-with-a-long-random-string
